# ScanCode.io Environment Configuration
# Copy this file to .env and customize the values

# =============================================================================
# SECURITY SETTINGS (REQUIRED)
# =============================================================================

# Generate a strong secret key for Django
# You can generate one with: openssl rand -base64 32
SECRET_KEY=your-very-secret-key-change-this-in-production

# Database password
DB_PASSWORD=your-secure-database-password

# =============================================================================
# NETWORK SETTINGS
# =============================================================================

# Hostnames/IP addresses that can access the application
# Use comma-separated values
ALLOWED_HOSTS=localhost,127.0.0.1,scancode.example.com,192.168.1.100

# CORS settings (for API access from other domains)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.example.com

# CSRF trusted origins
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://scancode.example.com

# =============================================================================
# PORT SETTINGS
# =============================================================================

# Port for the web application
WEB_PORT=8000

# Nginx ports (production profile)
NGINX_PORT=80
NGINX_SSL_PORT=443

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Worker memory limit (adjust based on your VM)
WORKER_MEMORY_LIMIT=8G

# Worker timeout in seconds (for large scans)
WORKER_TIMEOUT=3600

# Number of Gunicorn workers (usually 2-4 x CPU cores)
GUNICORN_WORKERS=4

# =============================================================================
# DEBUG SETTINGS
# =============================================================================

# Set to True for development (NOT for production!)
DEBUG=False

# =============================================================================
# STORAGE SETTINGS
# =============================================================================

# Workspace size limit (in GB)
WORKSPACE_SIZE_LIMIT=100

# Cache size limit (in GB)
CACHE_SIZE_LIMIT=50